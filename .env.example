# Tooth Kingdom Adventure — Environment Variables
# Copy this file to .env and fill in your values

# JWT Secret (change in production!)
JWT_SECRET_KEY=tooth-kingdom-secret-2024-change-in-prod

# Google Gemini API Key (for Tanu AI chatbot)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API Key (for Tanu voice TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# SMTP Email (for OTP delivery)
SMTP_EMAIL=toothkingdomadventures@gmail.com
SMTP_PASSWORD=your_app_password_here
