# Firebase Configuration (for Google Sign-In only)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend URL (optional — auto-detected for localhost)
# Set this to your deployed server URL for production
# VITE_LOCAL_BACKEND_URL=http://your-server-ip:8010

# Backend mode (set to false to disable local backend)
VITE_USE_LOCAL_BACKEND=true
