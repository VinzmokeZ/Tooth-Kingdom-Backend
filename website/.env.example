# Tooth Kingdom Adventure — Frontend Environment Variables
# Copy this file to .env and replace YOUR_COLLEGE_URL with your server IP or domain

# College/Server Backend URL
# Example: http://192.168.1.50:8010  or  http://project.college.edu:8010
VITE_LOCAL_BACKEND_URL=http://YOUR_COLLEGE_URL:8010

# App Mode
VITE_APP_MODE=production
